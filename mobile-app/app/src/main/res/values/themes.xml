<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base — Material Design 3 -->
    <style name="Theme.Slior" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- Tema sin ActionBar (para pantallas con toolbar custom) -->
    <style name="Theme.Slior.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/secondary</item>
    </style>
</resources>
