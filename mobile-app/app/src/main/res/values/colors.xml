    <color name="primary_light">#5E92F3</color>      <!-- Azul claro -->
    <color name="on_primary">#FFFFFF</color>         <!-- Texto sobre primario -->

    <!-- ======= Colores secundarios ======= -->
    <color name="secondary">#FF6F00</color>          <!-- Naranja (acción) -->
